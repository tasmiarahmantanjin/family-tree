# Test environment — used by Jest
# Copy to .env.test and it will be loaded automatically when running `npm test`

NODE_ENV=test
PORT=3002
FRONTEND_URL=http://localhost:3000

# Test database (separate from dev) — must contain "test" in hostname or db name.
# The safety guard in src/config/database.ts refuses to run tests otherwise.
DATABASE_URL=postgres://test:test@localhost:5433/family_tree_test
DATABASE_SSL=false

# Auth secrets — dummy values are fine for tests, but they must be present
# and long enough to satisfy the minimum-length checks in the auth utils.
JWT_ACCESS_SECRET=test-access-secret-minimum-32-chars-long-please
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
OAUTH_STATE_SECRET=test-oauth-state-secret-minimum-32-chars-please
GOOGLE_OAUTH_CLIENT_ID=test-client-id
GOOGLE_OAUTH_CLIENT_SECRET=test-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback
APP_URL=http://localhost:3000
