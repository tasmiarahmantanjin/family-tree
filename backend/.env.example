# Server Configuration
PORT=3001
NODE_ENV=development

# CORS - Frontend URL (comma-separated list allowed)
FRONTEND_URL=http://localhost:3000

# Database - points to local Docker Postgres (started via docker-compose.yml)
# Run `docker compose up -d postgres` to start the local DB
DATABASE_URL=postgres://dev:dev@postgres:5432/family_tree_dev
# If running the backend directly on the host machine (not in Docker), use this instead:
# DATABASE_URL=postgres://dev:dev@localhost:5432/family_tree_dev
DATABASE_SSL=false

# ------------------------------------------------------------------
# Authentication (required once the auth system is enabled)
# ------------------------------------------------------------------

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-with-at-least-64-random-bytes
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# HMAC secret that seals the short-lived OAuth state cookie.
# Must be distinct from JWT_ACCESS_SECRET.
OAUTH_STATE_SECRET=replace-me-with-at-least-32-random-bytes

# Google OAuth credentials (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback

# Absolute URL of the frontend — used to redirect back after OAuth completes.
APP_URL=http://localhost:3000

# Optional cookie domain (leave blank for host-only cookies).
COOKIE_DOMAIN=

# NEVER put production credentials in this file.
# Production uses Aiven PostgreSQL + Google credentials via K8s Secret in the cluster.
