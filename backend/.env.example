# Server Configuration
PORT=3001
NODE_ENV=development

# CORS - Frontend URL
FRONTEND_URL=http://localhost:3000

# Database - PostgreSQL connection string
# For Aiven: copy the Service URI from your Aiven PostgreSQL service overview
DATABASE_URL=postgres://username:password@host:port/dbname

# Set to "false" for local PostgreSQL without SSL (e.g. Docker)
DATABASE_SSL=true
