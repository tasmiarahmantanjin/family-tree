# Server Configuration
PORT=3001
NODE_ENV=production

# CORS - Frontend URL (your production frontend domain)
FRONTEND_URL=https://app.yourdomain.com

# Database - PostgreSQL connection string
# Copy from your Aiven service overview page
DATABASE_URL=postgres://user:pass@host:port/dbname

# SSL for cloud-hosted PostgreSQL (true for Aiven, false for local)
DATABASE_SSL=true

# ------------------------------------------------------------------
# Authentication — supplied via K8s Secret `family-tree-auth-secrets`
# ------------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
OAUTH_STATE_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.yourdomain.com/api/v1/auth/google/callback
APP_URL=https://app.yourdomain.com
COOKIE_DOMAIN=.yourdomain.com
